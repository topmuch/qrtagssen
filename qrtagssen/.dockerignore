# ═══════════════════════════════════════════════════════════════
# QRTags - Docker Ignore
# Exclude files that shouldn't be in the Docker build context
# ═══════════════════════════════════════════════════════════════

# Dependencies
node_modules
.pnp
.pnp.js

# Build output
.next
out
dist

# Database files (use volumes in production)
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal
db/

# Environment & secrets
.env
.env.*
!.env.example

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
dev.log
server.log

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Git
.git
.gitignore

# Documentation
README.md
docs/
agent-ctx/

# Test
coverage/
.nyc_output/

# Misc
screenshot-*.png
tool-results/
download/
examples/
worklog.md
mini-services/
Caddyfile
